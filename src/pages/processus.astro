---
export const prerender = true
import Layout from '../layouts/Layout.astro'

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Combien de temps dure un projet en moyenne ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Entre 3 et 6 semaines selon la complexité. Un rebrand complet : 6 semaines. Un site web seul : 3 à 4 semaines. On vous donne un calendrier précis au brief.' },
    },
    {
      '@type': 'Question',
      name: 'Peut-on modifier le périmètre en cours de route ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oui, mais en toute transparence. Tout ajout de périmètre fait l\'objet d\'un avenant signé. On ne facture jamais une surprise.' },
    },
    {
      '@type': 'Question',
      name: 'Travaillez-vous avec des sous-traitants ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Parfois, sur des productions spécifiques (développement complexe, motion, photo). Toujours des profils sélectionnés par nos soins, sous notre responsabilité.' },
    },
    {
      '@type': 'Question',
      name: 'Quel est votre délai de réponse à un brief ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Moins de 48h. Si le projet nous correspond, on vous envoie une proposition de cadrage dans la foulée.' },
    },
    {
      '@type': 'Question',
      name: 'Que se passe-t-il si le résultat ne nous convient pas ?',
      acceptedAnswer: { '@type': 'Answer', text: 'On a 2 rounds de révisions inclus pour affiner. Si après ça on est vraiment bloqués (ce qui ne nous est pas arrivé), on tranche ensemble en session de travail.' },
    },
  ],
}
---

<Layout
  title="Processus — Méthode Advanguard Studio · Bruxelles"
  description="La méthode Advanguard Studio : 5 phases du brief au livrable. Brief, recherche, exploration, construction, livraison. 12 à 28 jours."
  canonical="https://advanguardstudio.com/processus"
  jsonLd={[faqSchema]}
>
  <div class="page-back" style="padding:10px 40px;font-size:12px;font-family:'JetBrains Mono',monospace;border-bottom:1px solid rgba(128,128,128,0.15);">
    <a href="/" style="opacity:0.5;text-decoration:none;letter-spacing:0.08em;">← Retour</a>
  </div>

  <section class="hero">
    <div class="wrap">
      <div class="hero-label mono">(Ch. 05) — Processus</div>
      <h1>On ne commence pas<br><em>par le logo.</em></h1>
      <p class="lede">Chaque projet Advanguard Studio suit une méthode éprouvée, que vous soyez <strong>en Belgique</strong> ou en remote. Pas un tunnel bureaucratique, mais un cadre qui libère la créativité là où elle doit s'exprimer. Du brief brut au livrable qui dure.</p>
      <div class="stats">
        <div class="stat">
          <div class="stat-val">12 à 28 jours</div>
          <div class="stat-desc">De l'intention au livrable</div>
        </div>
        <div class="stat">
          <div class="stat-val">100% direct</div>
          <div class="stat-desc">Aucun intermédiaire</div>
        </div>
        <div class="stat">
          <div class="stat-val">&lt; 48h</div>
          <div class="stat-desc">Premier retour garanti</div>
        </div>
      </div>
      <div style="margin-top:36px;display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/contact" class="pill filled" data-umami-event="cta_processus_hero">Démarrer un projet →</a>
      </div>
    </div>
  </section>

  <section class="phases-section">
    <div class="wrap">
      <div class="phase-row" data-phase>
        <div class="phase-num">01</div>
        <div class="phase-meta">
          <div class="phase-name">Brief & Écoute</div>
          <p class="phase-desc">On ne suppose rien. On pose les bonnes questions : marché, ambitions, contraintes, ce qui a déjà échoué. Un brief mal posé est la première cause d'un mauvais design.</p>
        </div>
        <div class="phase-actions">
          <ul>
            <li>Appel de découverte 90 min</li>
            <li>Questionnaire stratégique</li>
            <li>Analyse des références concurrentes</li>
            <li>Validation des objectifs mesurables</li>
            <li>Signature & acompte</li>
          </ul>
        </div>
        <div class="dur-badge">1–2 jours</div>
      </div>

      <div class="phase-row" data-phase>
        <div class="phase-num">02</div>
        <div class="phase-meta">
          <div class="phase-name">Recherche & Stratégie</div>
          <p class="phase-desc">On creuse avant de dessiner. Benchmark approfondi, analyse sémiotique, définition du territoire. On pose la plateforme créative qui guidera toutes les décisions formelles.</p>
        </div>
        <div class="phase-actions">
          <ul>
            <li>Benchmark 20+ références</li>
            <li>Analyse sémiotique</li>
            <li>Plateforme de marque</li>
            <li>Territoire visuel & verbal</li>
            <li>Moodboard directionnel</li>
            <li>Validation client</li>
          </ul>
        </div>
        <div class="dur-badge">3–5 jours</div>
      </div>

      <div class="phase-row" data-phase>
        <div class="phase-num">03</div>
        <div class="phase-meta">
          <div class="phase-name">Exploration créative</div>
          <p class="phase-desc">Le seul moment où tout est permis. On génère beaucoup pour garder peu. Trois directions minimum, chacune cohérente, défendable, différenciante. Pas de variantes, des partis-pris.</p>
        </div>
        <div class="phase-actions">
          <ul>
            <li>3 directions créatives distinctes</li>
            <li>Présentation commentée</li>
            <li>Feedback structuré</li>
            <li>Pivot ou affinage selon retours</li>
          </ul>
        </div>
        <div class="dur-badge">4–8 jours</div>
      </div>

      <div class="phase-row" data-phase>
        <div class="phase-num">04</div>
        <div class="phase-meta">
          <div class="phase-name">Construction & Affinage</div>
          <p class="phase-desc">La direction retenue devient un système. On construit la cohérence, on teste sur les vrais supports, on élague ce qui résiste mal. Le design n'est pas fini quand il est beau. Il est fini quand il ne peut plus être amélioré.</p>
        </div>
        <div class="phase-actions">
          <ul>
            <li>Développement complet de la direction</li>
            <li>Tests supports réels</li>
            <li>2 rounds de révisions inclus</li>
            <li>Vérification technique</li>
            <li>Préparation des livrables finaux</li>
          </ul>
        </div>
        <div class="dur-badge">5–10 jours</div>
      </div>

      <div class="phase-row" data-phase>
        <div class="phase-num">05</div>
        <div class="phase-meta">
          <div class="phase-name">Livraison & Transmission</div>
          <p class="phase-desc">On ne lâche pas un fichier zip. On transmet un système. Formats, modes d'emploi, conventions de nommage, do/don't, pour que ce qu'on a construit ensemble reste utilisable sans nous.</p>
        </div>
        <div class="phase-actions">
          <ul>
            <li>Package de fichiers complet</li>
            <li>Brand book ou guidelines</li>
            <li>Session de passation 60 min</li>
            <li>Support 30 jours post-livraison</li>
          </ul>
        </div>
        <div class="dur-badge">1–2 jours</div>
      </div>
    </div>
  </section>

  <section class="principles-section">
    <div class="wrap">
      <div class="principles-header">
        <div class="section-label mono">Notre cadre</div>
        <h2>Les règles du <em>jeu.</em></h2>
      </div>
      <div class="principles-grid">
        <div class="principle-card">
          <div class="principle-accent">Studio</div>
          <div class="principle-title">Vous parlez aux gens qui font</div>
          <p class="principle-desc">Pas d'account manager entre vous et le travail. Le créatif qui répond à vos mails est celui qui tient le stylet.</p>
        </div>
        <div class="principle-card">
          <div class="principle-accent">Révisions</div>
          <div class="principle-title">Deux rounds, pas une infinité</div>
          <p class="principle-desc">On inclut deux cycles de feedback. Pas pour limiter, pour garder la dynamique. Un projet qui tourne en rond ne sort jamais bon.</p>
        </div>
        <div class="principle-card">
          <div class="principle-accent">Devis</div>
          <div class="principle-title">Ce qu'on signe, on le tient</div>
          <p class="principle-desc">Le prix annoncé est le prix facturé. Si le périmètre change, on en parle avant, jamais après.</p>
        </div>
        <div class="principle-card">
          <div class="principle-accent">Parole</div>
          <div class="principle-title">On dit ce qu'on pense</div>
          <p class="principle-desc">Si une direction ne tient pas la route, on le dit. On ne vend pas des validations, on cherche ce qui fonctionne vraiment.</p>
        </div>
        <div class="principle-card">
          <div class="principle-accent">Fichiers</div>
          <div class="principle-title">Tout vous appartient, dès la livraison</div>
          <p class="principle-desc">Sources, droits, exports : rien ne reste chez nous. Vous repartez avec l'intégralité, sans clause de rachat.</p>
        </div>
        <div class="principle-card">
          <div class="principle-accent">Impact</div>
          <div class="principle-title">Un livrable qui travaille pour vous</div>
          <p class="principle-desc">On pose les critères de succès au brief. Pas pour se couvrir, pour savoir ensemble quand on a vraiment réussi.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="wrap">
      <div class="faq-header">
        <div class="faq-label mono">FAQ</div>
        <h2>Questions fréquentes</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" type="button">
            Combien de temps dure un projet en moyenne ?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a"><div class="faq-a-inner">Entre 3 et 6 semaines selon la complexité. Un rebrand complet : 6 semaines. Un site web seul : 3 à 4 semaines. On vous donne un calendrier précis au brief.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" type="button">
            Peut-on modifier le périmètre en cours de route ?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a"><div class="faq-a-inner">Oui, mais en toute transparence. Tout ajout de périmètre fait l'objet d'un avenant signé. On ne facture jamais une surprise.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" type="button">
            Travaillez-vous avec des sous-traitants ?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a"><div class="faq-a-inner">Parfois, sur des productions spécifiques (développement complexe, motion, photo). Toujours des profils sélectionnés par nos soins, sous notre responsabilité.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" type="button">
            Quel est votre délai de réponse à un brief ?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a"><div class="faq-a-inner">Moins de 48h. Si le projet nous correspond, on vous envoie une proposition de cadrage dans la foulée.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" type="button">
            Que se passe-t-il si le résultat ne nous convient pas ?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a"><div class="faq-a-inner">On a 2 rounds de révisions inclus pour affiner. Si après ça on est vraiment bloqués (ce qui ne nous est pas arrivé), on tranche ensemble en session de travail.</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="wrap">
      <h2>Prêt à démarrer <em>votre projet ?</em></h2>
      <p>Décrivez-nous votre situation en quelques lignes. On revient vers vous sous 48h avec un premier cadrage.</p>
      <div class="cta-pills">
        <a href="mailto:hello@advanguardstudio.com" class="pill pill-filled">hello@advanguardstudio.com →</a>
        <a href="/contact" class="pill pill-outline">Prendre un appel de 30 min</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.faq-q').forEach(function(btn){
      btn.setAttribute('aria-expanded', 'false');
      btn.addEventListener('click', function(){
        var item = btn.closest('.faq-item');
        if(!item) return;
        item.classList.toggle('open');
        btn.setAttribute('aria-expanded', item.classList.contains('open') ? 'true' : 'false');
      });
    });
  </script>
</Layout>
