---
export const prerender = true
import Layout from '../layouts/Layout.astro'

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://www.advanguardstudio.com/a-propos#aboutpage',
  url: 'https://www.advanguardstudio.com/a-propos',
  name: 'À propos — Advanguard Studio',
  description:
    "Découvrez l'histoire, la méthode et l'équipe d'Advanguard Studio, studio de design indépendant basé à Bruxelles.",
  inLanguage: 'fr-BE',
  isPartOf: {
    '@id': 'https://www.advanguardstudio.com/#website',
  },
  mainEntity: {
    '@id': 'https://www.advanguardstudio.com/#organization',
  },
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://www.advanguardstudio.com' },
    { '@type': 'ListItem', position: 2, name: 'À propos', item: 'https://www.advanguardstudio.com/a-propos' },
  ],
}

const team = [
  {
    role: 'Direction créative',
    title: 'Le cap, le goût, les arbitrages.',
    text: "On transforme les objectifs business en territoire de marque lisible : positionnement, récit, direction visuelle et standards d'exécution.",
  },
  {
    role: 'Identité & systèmes',
    title: 'Des marques qui tiennent debout.',
    text: 'Logotypes, typographies, palettes, guidelines et composants : chaque signe sert un usage réel, pas seulement une belle présentation.',
  },
  {
    role: 'Web & produit',
    title: 'Interfaces rapides, propres, durables.',
    text: "Sites Astro, expériences web, design systems et interfaces SaaS : on construit pour la clarté, la vitesse et l'autonomie des équipes.",
  },
  {
    role: 'Réseau créatif',
    title: 'Les bons profils au bon moment.',
    text: 'Motion, photo, illustration, développement spécifique : le studio s’entoure de spécialistes quand le projet le demande, sous une direction unique.',
  },
]

const milestones = [
  {
    year: '2024',
    title: 'Naissance du studio',
    text: "Advanguard Studio se construit à Bruxelles autour d'une idée simple : réunir stratégie, design et exécution dans un format direct.",
  },
  {
    year: '2025',
    title: 'Du branding aux systèmes',
    text: "Les missions s'élargissent : identité, web, interfaces, formations et accompagnement d'équipes. Moins de silos, plus de continuité.",
  },
  {
    year: '2026',
    title: 'Studio polyvalent',
    text: "Le studio assume son terrain : aider les marques ambitieuses à devenir remarquables, avec des livrables utiles longtemps après la livraison.",
  },
]
---

<Layout
  title="À propos — Advanguard Studio · Bruxelles"
  description="L'histoire, l'équipe et la méthode d'Advanguard Studio, studio de design indépendant basé à Bruxelles. Branding, web, formations et consulting."
  canonical="https://www.advanguardstudio.com/a-propos"
  jsonLd={[aboutPageSchema, breadcrumbSchema]}
>
  <div class="page-back" style="padding:10px 40px;font-size:12px;font-family:'JetBrains Mono',monospace;border-bottom:1px solid rgba(128,128,128,0.15);">
    <a href="/" style="opacity:0.5;text-decoration:none;letter-spacing:0.08em;">← Accueil</a>
  </div>

  <section class="hero">
    <div class="wrap">
      <div class="hero-label mono">(Ch. 00) — À propos</div>
      <h1>Un studio indépendant<br><em>basé à Bruxelles.</em></h1>
      <p class="lede">
        Advanguard Studio conçoit des identités, des interfaces et des systèmes visuels pour les entreprises qui veulent être comprises vite, reconnues clairement et choisies durablement. Belgium, worldwide.
      </p>
      <div class="stats">
        <div class="stat">
          <div class="stat-val">Depuis 2024</div>
          <div class="stat-desc">Studio à Bruxelles</div>
        </div>
        <div class="stat">
          <div class="stat-val">Format direct</div>
          <div class="stat-desc">Peu d'intermédiaires</div>
        </div>
        <div class="stat">
          <div class="stat-val">Brand → Web</div>
          <div class="stat-desc">Systèmes complets</div>
        </div>
      </div>
      <div style="margin-top:36px;display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/contact" class="pill filled" data-umami-event="cta_about_hero">Démarrer un projet →</a>
      </div>
    </div>
  </section>

  <section class="process" aria-label="Histoire de l'agence">
    <div class="wrap">
      <div class="section-head">
        <div class="k">Histoire</div>
        <h2>Un studio qui se construit <em>en trois temps.</em></h2>
        <div class="mono">2024 → 2026</div>
      </div>

      <div class="proc-grid">
        {milestones.map((item, idx) => (
          <div class="step">
            <div class="num">{String(idx + 1).padStart(2, '0')}</div>
            <div class="k">{item.year}</div>
            <h5>{item.title}</h5>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="process" aria-label="Équipe">
    <div class="wrap">
      <div class="section-head">
        <div class="k">Équipe</div>
        <h2>Un noyau serré, <em>un réseau solide.</em></h2>
        <div class="mono">4 / rôles</div>
      </div>

      <div class="proc-grid">
        {team.map((member, idx) => (
          <div class="step">
            <div class="num">{String(idx + 1).padStart(2, '0')}</div>
            <div class="k">{member.role}</div>
            <h5>{member.title}</h5>
            <p>{member.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="process" aria-label="Principes de travail">
    <div class="wrap">
      <div class="section-head">
        <div class="k">Principes</div>
        <h2>Clarté, exigence, <em>continuité.</em></h2>
        <div class="mono">3 / règles</div>
      </div>

      <div class="proc-grid">
        <div class="step">
          <div class="num">01</div>
          <div class="k">Clarté</div>
          <h5>Compris avant d'être admiré</h5>
          <p>Une marque doit être lisible, assumée et cohérente avant de chercher l'effet.</p>
        </div>
        <div class="step">
          <div class="num">02</div>
          <div class="k">Exigence</div>
          <h5>Chaque détail visible parle</h5>
          <p>On privilégie les partis-pris défendables et des standards qui tiennent en production.</p>
        </div>
        <div class="step">
          <div class="num">03</div>
          <div class="k">Continuité</div>
          <h5>Utile longtemps après la livraison</h5>
          <p>Guidelines, composants, handoff : le système doit rester simple à utiliser pour vos équipes.</p>
        </div>
        <div class="step">
          <div class="num">04</div>
          <div class="k">Contact</div>
          <h5>On en parle ?</h5>
          <p><a href="/contact">Réserver un appel</a> ou envoyer un message, réponse sous 24h.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
