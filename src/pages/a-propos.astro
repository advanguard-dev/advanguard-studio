---
export const prerender = true
import Layout from '../layouts/Layout.astro'

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://www.advanguardstudio.com/a-propos#aboutpage',
  url: 'https://www.advanguardstudio.com/a-propos',
  name: 'À propos — Advanguard Studio',
  description:
    "Découvrez l'histoire, la méthode et l'équipe d'Advanguard Studio, studio de design indépendant basé à Bruxelles.",
  inLanguage: 'fr-BE',
  isPartOf: {
    '@id': 'https://www.advanguardstudio.com/#website',
  },
  mainEntity: {
    '@id': 'https://www.advanguardstudio.com/#organization',
  },
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://www.advanguardstudio.com' },
    { '@type': 'ListItem', position: 2, name: 'À propos', item: 'https://www.advanguardstudio.com/a-propos' },
  ],
}

const team = [
  {
    role: 'Direction créative',
    title: 'Le cap, le goût, les arbitrages.',
    text: "On transforme les objectifs business en territoire de marque lisible : positionnement, récit, direction visuelle et standards d'exécution.",
  },
  {
    role: 'Identité & systèmes',
    title: 'Des marques qui tiennent debout.',
    text: 'Logotypes, typographies, palettes, guidelines et composants : chaque signe sert un usage réel, pas seulement une belle présentation.',
  },
  {
    role: 'Web & produit',
    title: 'Interfaces rapides, propres, durables.',
    text: "Sites Astro, expériences web, design systems et interfaces SaaS : on construit pour la clarté, la vitesse et l'autonomie des équipes.",
  },
  {
    role: 'Réseau créatif',
    title: 'Les bons profils au bon moment.',
    text: 'Motion, photo, illustration, développement spécifique : le studio s’entoure de spécialistes quand le projet le demande, sous une direction unique.',
  },
]

const milestones = [
  {
    year: '2024',
    title: 'Naissance du studio',
    text: "Advanguard Studio se construit à Bruxelles autour d'une idée simple : réunir stratégie, design et exécution dans un format direct.",
  },
  {
    year: '2025',
    title: 'Du branding aux systèmes',
    text: "Les missions s'élargissent : identité, web, interfaces, formations et accompagnement d'équipes. Moins de silos, plus de continuité.",
  },
  {
    year: '2026',
    title: 'Studio polyvalent',
    text: "Le studio assume son terrain : aider les marques ambitieuses à devenir remarquables, avec des livrables utiles longtemps après la livraison.",
  },
]
---

<Layout
  title="À propos — Advanguard Studio · Bruxelles"
  description="L'histoire, l'équipe et la méthode d'Advanguard Studio, studio de design indépendant basé à Bruxelles. Branding, web, formations et consulting."
  canonical="https://www.advanguardstudio.com/a-propos"
  jsonLd={[aboutPageSchema, breadcrumbSchema]}
>
  <div class="page-back" style="padding:10px 40px;font-size:12px;font-family:'JetBrains Mono',monospace;border-bottom:1px solid rgba(128,128,128,0.15);">
    <a href="/" style="opacity:0.5;text-decoration:none;letter-spacing:0.08em;">← Accueil</a>
  </div>

  <main class="about-page">
    <section class="about-hero wrap">
      <div class="about-kicker">À propos — Advanguard Studio</div>
      <div class="about-hero-grid">
        <h1>Un studio indépendant pour les marques qui veulent <em>tenir dans le temps.</em></h1>
        <div class="about-intro">
          <p>
            Advanguard Studio est un studio de design basé à Bruxelles. On conçoit des identités, des interfaces et des systèmes visuels pour les entreprises qui ont besoin d'être comprises vite, reconnues clairement et choisies durablement.
          </p>
          <p>
            Notre format est volontairement resserré : peu d'intermédiaires, des décisions nettes, une implication directe sur la stratégie comme sur les détails.
          </p>
        </div>
      </div>
      <div class="about-signal" aria-hidden="true">
        <span>ADVG</span>
        <span>BRU</span>
        <span>2024</span>
      </div>
    </section>

    <section class="wrap about-band">
      <div class="about-statement">
        <span class="mono">Notre histoire</span>
        <p>
          Le studio est né d'un constat simple : beaucoup de marques ne manquent pas d'idées, elles manquent d'un système pour les rendre visibles, cohérentes et actionnables. Advanguard Studio existe pour faire ce lien entre ambition, design et mise en œuvre.
        </p>
      </div>
    </section>

    <section class="wrap about-timeline" aria-label="Histoire de l'agence">
      {milestones.map((item) => (
        <article class="timeline-row">
          <div class="timeline-year">{item.year}</div>
          <div>
            <h2>{item.title}</h2>
            <p>{item.text}</p>
          </div>
        </article>
      ))}
    </section>

    <section class="wrap about-team" aria-labelledby="team-title">
      <div class="section-head compact">
        <div class="k">Équipe</div>
        <h2 id="team-title">Un noyau serré, <em>un réseau solide.</em></h2>
        <div class="mono">4 / rôles</div>
      </div>

      <div class="team-grid">
        {team.map((member) => (
          <article class="team-item">
            <div class="team-role">{member.role}</div>
            <h3>{member.title}</h3>
            <p>{member.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="wrap about-values" aria-label="Principes de travail">
      <div>
        <span class="mono">Ce qu'on protège</span>
        <h2>Clarté, exigence, continuité.</h2>
      </div>
      <div class="values-list">
        <p><strong>Clarté.</strong> Une marque doit être comprise avant d'être admirée.</p>
        <p><strong>Exigence.</strong> Chaque détail visible raconte quelque chose de votre niveau.</p>
        <p><strong>Continuité.</strong> Le bon design ne s'arrête pas au fichier final : il doit rester facile à utiliser.</p>
      </div>
    </section>

    <section class="about-cta wrap">
      <h2>Parlons de ce que votre marque doit devenir.</h2>
      <a href="/contact" class="pill filled" data-umami-event="cta_about_contact">Démarrer un projet →</a>
    </section>
  </main>
</Layout>

<style>
  .about-page {
    overflow: hidden;
  }

  .about-hero {
    padding-top: 96px;
    padding-bottom: 40px;
  }

  .about-kicker,
  .team-role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--char);
  }

  .about-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, .75fr);
    gap: clamp(36px, 7vw, 96px);
    align-items: end;
    margin-top: 28px;
  }

  .about-hero h1 {
    margin: 0;
    max-width: 1050px;
    font-size: clamp(56px, 10vw, 148px);
    line-height: .86;
    letter-spacing: -.045em;
    text-transform: uppercase;
  }

  .about-hero h1 em,
  .about-team h2 em {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    text-transform: none;
  }

  .about-intro {
    display: grid;
    gap: 18px;
    color: var(--char);
    font-size: clamp(17px, 1.7vw, 22px);
    line-height: 1.45;
  }

  .about-intro p,
  .about-statement p,
  .timeline-row p,
  .team-item p,
  .values-list p {
    margin: 0;
  }

  .about-signal {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 56px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: .12em;
    color: var(--char);
  }

  .about-signal span {
    padding: 18px 0;
    border-right: 1px solid var(--rule);
  }

  .about-signal span:last-child {
    border-right: 0;
    text-align: right;
  }

  .about-signal span:nth-child(2) {
    text-align: center;
  }

  .about-band {
    padding-top: 56px;
    padding-bottom: 72px;
  }

  .about-statement {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(24px, 6vw, 88px);
    padding: clamp(32px, 7vw, 72px) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .about-statement p {
    max-width: 980px;
    font-size: clamp(28px, 4.6vw, 68px);
    line-height: .98;
    letter-spacing: -.035em;
  }

  .about-timeline {
    padding-top: 16px;
    padding-bottom: 88px;
  }

  .timeline-row {
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: clamp(24px, 6vw, 96px);
    padding: 32px 0;
    border-top: 1px solid var(--rule);
  }

  .timeline-row:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .timeline-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--orange);
  }

  .timeline-row h2,
  .about-values h2,
  .about-cta h2 {
    margin: 0;
    font-size: clamp(30px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -.03em;
  }

  .timeline-row p {
    max-width: 760px;
    margin-top: 12px;
    color: var(--char);
    font-size: 17px;
    line-height: 1.55;
  }

  .section-head.compact {
    padding-top: 24px;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }

  .team-item {
    min-height: 320px;
    padding: clamp(22px, 3vw, 34px);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
  }

  .team-item h3 {
    margin: auto 0 18px;
    font-size: clamp(24px, 2.6vw, 38px);
    line-height: 1;
    letter-spacing: -.025em;
  }

  .team-item p {
    color: var(--char);
    font-size: 15px;
    line-height: 1.55;
  }

  .about-values {
    display: grid;
    grid-template-columns: minmax(0, .8fr) minmax(320px, 1fr);
    gap: clamp(32px, 8vw, 120px);
    padding-top: 96px;
    padding-bottom: 96px;
  }

  .values-list {
    display: grid;
    gap: 18px;
    color: var(--char);
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.4;
  }

  .values-list strong {
    color: var(--ink);
  }

  .about-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 56px;
    padding-bottom: 96px;
    border-top: 1px solid var(--rule);
  }

  .about-cta h2 {
    max-width: 820px;
  }

  @media (max-width: 1000px) {
    .about-hero-grid,
    .about-statement,
    .about-values {
      grid-template-columns: 1fr;
    }

    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .about-hero {
      padding-top: 56px;
    }

    .about-hero h1 {
      font-size: clamp(48px, 17vw, 76px);
      letter-spacing: -.04em;
    }

    .about-signal {
      grid-template-columns: 1fr;
    }

    .about-signal span,
    .about-signal span:nth-child(2),
    .about-signal span:last-child {
      text-align: left;
      border-right: 0;
      border-bottom: 1px solid var(--rule);
    }

    .about-signal span:last-child {
      border-bottom: 0;
    }

    .timeline-row {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .team-grid {
      grid-template-columns: 1fr;
    }

    .team-item {
      min-height: 260px;
    }

    .about-cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
